<div id="search">
    <input
        id="searchBar"
        type="search"
        placeholder="Search for anything"
        autofocus
    />
    <ul id="searchResults"></ul>
    <p id="hint"></p>
</div>

<style lang="scss">
    @keyframes fadeIn {
        0% {
            opacity: 0;
        }

        100% {
            opacity: 1;
        }
    }

    div {
        width: 100%;
        display: none;

        p {
            text-align: center;
            animation: fadeIn 0.25s;
        }

        input {
            width: 100%;
            background-color: var(--variant);
            border: none;
            padding: 0.75rem;
            border-radius: 0.75rem;
            color: var(--text);
            font-size: 1.25rem;
            text-align: center;
            position: relative;

            &:focus-visible {
                outline: none;
            }
        }

        ul {
            display: none;
            flex-direction: column;
            gap: 0.5rem;
            background-color: var(--variant);
            border-radius: 0.75rem;
            padding: 0.5rem;
            position: absolute;
            overflow: auto;
            max-height: 75vh;
            width: 100%;

            :global(a) {
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 0.5rem;
                border-radius: 0.5rem;
                text-decoration: none;
                color: var(--text);
                transition: 0.25s;
                padding: 1rem;

                &:hover {
                    color: var(--primary-text);
                    background-color: var(--primary-bg);

                    :global(p).desc {
                        filter: opacity(75%);
                    }

                    :global(svg) {
                        fill: var(--primary-text);
                    }
                }

                :global(div) {
                    display: flex;
                    justify-content: center;
                    align-items: center;

                    :global(img) {
                        display: inline-flex;
                        align-self: center;
                        justify-self: center;
                        height: 1.25rem;
                        margin-right: 0.5rem;
                    }

                    :global(svg) {
                        display: inline-flex;
                        align-self: center;
                        justify-self: center;
                        height: 1.25rem;
                        margin-right: 0.5rem;
                        fill: var(--text);
                        transition: 0.25s;
                    }
                }

                :global(p) {
                    font-size: 1.25rem;
                    text-align: center;
                    margin: 0;

                    &.desc {
                        filter: opacity(50%);
                    }
                }
            }
        }
    }
</style>

<script src="../scripts/search.ts"></script>
<script>
    // Only load search component if JS is enabled
    const searchComponent = document.getElementById("search")!;
    searchComponent.style.display = "initial";
    
    const hints = [
        "Hint: Type * to see all results!",
        "Try searching for my blog!",
        "Say cheese! Check out my photography by searching for it!",
        "Wanna talk? Search for my Matrix!",
        "All my work is open source, check it out by searching for 'GitHub'!",
        "If you wanna see all of my posts, try searching for 'posts'!",
        "Yearning for the ye olden days? Search for 'history'!",
        "In a science-y mood? Try searching for 'science'!",
        "Learn about our digital world by searching for 'tech'!",
        "Like my stuff? Consider donating by searching for 'donate'!",
    ];

    document.getElementById("hint")!.innerHTML =
        hints[Math.floor(Math.random() * hints.length)];
</script>
