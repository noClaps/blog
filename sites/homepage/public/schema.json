{
    "$schema": "http://json-schema.org/schema",
    "$id": "https://zerolimits.dev/schema.json",
    "title": "ZeroLimits.dev links",
    "type": "object",
    "properties": {
        "links": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string"
                    },
                    "favicon": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "minItems": 1,
                        "uniqueItems": true
                    }
                }
            },
            "required": [
                "url",
                "favicon",
                "title",
                "description",
                "tags"
            ]
        }
    }
}