---
import { Icon } from "@noclaps/icons";
const { title } = Astro.props;
---

<div class="warning">
  <p>
    <Icon name="warning" />
    <b>{title ? title : "WARNING"}</b>
  </p>
  <slot />
</div>

<style>
  .warning {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    background-color: var(--warning-bg);
    color: var(--warning-text);
    margin: 0.5rem 0;
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }
</style>
