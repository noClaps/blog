{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/noClaps/ZeroLimits.dev.git"
  },
  "author": "noClaps",
  "license": "0BSD",
  "workspaces": [
    "packages/*",
    "sites/*"
  ],
  "scripts": {
    "dev": "turbo start",
    "dev:blog": "turbo start --filter=blog",
    "dev:gallery": "turbo start --filter=gallery",
    "dev:homepage": "turbo start --filter=homepage",
    "dev:docs": "turbo start --filter=docs",
    "build": "turbo build",
    "build:blog": "turbo build --filter=blog",
    "build:gallery": "turbo build --filter=gallery",
    "build:homepage": "turbo build --filter=homepage",
    "build:docs": "turbo build --filter=docs",
    "preview": "turbo preview",
    "preview:blog": "turbo preview --filter=blog",
    "preview:gallery": "turbo preview --filter=gallery",
    "preview:homepage": "turbo preview --filter=homepage",
    "preview:docs": "turbo preview --filter=docs",
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.26.2",
    "turbo": "^1.10.9"
