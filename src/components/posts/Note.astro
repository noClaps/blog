---
interface Props {
  title?: string;
}

const { title = "NOTE" } = Astro.props;
---

<div class="note">
  <p>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-sticky-note"
      ><path
        d="M15.5 3H5a2 2 0 0 0-2 2v14c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2V8.5L15.5 3Z"
      ></path><path d="M15 3v6h6"></path></svg
    >
    <b>{title}</b>
  </p>
  <slot />
</div>

<style>
  .note {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 0.5rem 0;
    background-color: oklch(var(--note) / 25%);
    border: 0.125rem solid oklch(var(--note));
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
