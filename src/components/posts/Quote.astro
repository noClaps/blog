<template id="b-quote">
  <p>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-message-square"
      ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
      ></path></svg
    >
	<b id="title">
    	<a target="_blank" rel="noopener noreferrer"></a>
	</b>
  </p>
</template>

<script>
	import { marked } from "marked"
	class BQuote extends HTMLElement {
		constructor() {
			super()
			
			const template = document.querySelector("#b-quote")
			if (!template) throw new Error("Quote template not found")

			const title = this.getAttribute("title") ?? "QUOTE"
			const href = this.getAttribute("href")
			console.log(this.innerText)
			const content = this.innerHTML.trim()
			this.innerHTML = template.innerHTML

			const titleSection = this.querySelector("#title")
			if (!titleSection) throw new Error("Quote title section not found")

			if (href) {
				const link = titleSection.querySelector("a")
				if (!link) throw new Error("Quote title link element not found")

				link.href = href
				link.innerHTML = title
			} else {
				titleSection.innerHTML = title
			}

			this.insertAdjacentHTML("beforeend", marked.parse(content) as string)
		}
	}

	customElements.define("b-quote", BQuote)
</script>

<style>
  :global(b-quote) {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 0.5rem 0;
    background-color: oklch(var(--quote) / 25%);
    border: 0.125rem solid oklch(var(--quote));
  }

  p {
    margin: 0;
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  b {
    vertical-align: middle;
  }

  a {
    color: var(--text);
	text-decoration: underline;
  }
</style>
