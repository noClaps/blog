---
import Icon from "../Icon.astro";

interface Props {
  title?: string;
}

const { title = "WARNING" } = Astro.props;
---

<div class="warning">
  <p>
    <Icon name="alertTriangle" />
    <b>{title}</b>
  </p>
  <slot />
</div>

<style>
  .warning {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 0.5rem 0;
    background-color: oklch(var(--warning) / 25%);
    border: 0.125rem solid oklch(var(--warning));
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
