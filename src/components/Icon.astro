---
// @ts-ignore
// Need to do this as there is no type declaration for lucide-static
import Lucide from "lucide-static";

interface Props {
    name: string;
}

const { name, ...props } = Astro.props;

// Source: https://github.com/dzeiocom/lucide-astro/blob/master/src/build.js
function fillTemplate(icon: string) {
    return icon
        .replace(/<svg(?:.|\n)*?>((?:.|\n)*)<\/svg>/gm, "$1")
        .replace(/  /g, "\t")
        .trim();
}
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    set:html={fillTemplate(Lucide[name])}
    {...props}
/>
