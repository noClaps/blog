---
interface Props {
  title: string;
  description?: string;
  href: string;
  date: Date;
  author: string;
}

const { title, description, href, date, author } = Astro.props;
---

<a href={`/${href}`} title={title}>
  <time datetime={date.toISOString()}>{date.toDateString()}</time>
  <h4>{title}</h4>
  {description ?? <p>{description}</p>}
  <p>Written by {author}</p>
</a>

<style>
  a {
    color: var(--text);
    border: 0.125rem solid var(--primary);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    border-radius: 0.5rem;
    background-color: var(--background);
    transition: all 0.25s;

    &:hover {
      box-shadow: 0 0 0.5rem 0.25rem var(--primary);
      text-decoration: none;
    }
  }

  h4,
  p,
  time {
    margin: 0.25rem;
  }

  h4 {
    font-size: 1.25rem;
  }

  time {
    font-style: italic;
  }
</style>
