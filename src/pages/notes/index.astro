---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Link from "@/components/Link.astro";
import Icon from "@/components/Icon.astro";

const notes = await getCollection("notes").then((notes) => {
    return notes.sort((a, b) => {
        const aDate = a.data.lastmod ?? a.data.date;
        const bDate = b.data.lastmod ?? b.data.date;

        if (aDate > bDate) return -1;
        if (aDate < bDate) return 1;
        return 0;
    });
});
---

<BaseLayout title="Notes">
    <main>
        <span>
            <h1>Notes</h1>
            <a href="/notes.rss"><Icon name="rss" /></a>
        </span>
        <div>
            {
                notes.map((note) => (
                    <Link
                        title={note.data.title}
                        href={`notes/${note.slug}`}
                        date={note.data.lastmod ?? note.data.date}
                        author={note.data.author.id}
                    />
                ))
            }
        </div>
    </main>
</BaseLayout>

<style>
    h1 {
        font-size: min(5rem, 15vmin);
        color: var(--primary);
        margin-bottom: 0.5rem;
        width: min-content;
    }

    a {
        color: var(--text);
        transition: all 0.25s;
        margin-bottom: 1.5rem;
        width: min-content;

        &:hover {
            color: var(--primary);
        }
    }

    span {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    div {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
</style>
