---
import { Icon, Layout } from "@noclaps/components";

import "../styles/global.css";
import "../styles/colors.css";

const {
  title,
  description = "A website to showcase some cool photos I've taken.",
} = Astro.props;
---

<Layout site="gallery" {title} {description}>
  <a
    href="https://github.com/noClaps/ZeroLimits.dev/releases/download/2023-08-13/Photos.zip"
    title="download"
    slot="header"><Icon name="download" />Download</a
  >
  <slot />
</Layout>

<style>
  a {
    display: flex;
    gap: 0.125rem;
    text-decoration: none;
    transition: all 0.25s;
    color: var(--text);
    font-weight: 550;
    padding: 0.25rem;
    border-radius: 0.25rem;

    &:hover {
      background-color: var(--primary);
      color: var(--on-primary);
    }
  }
</style>
