---
import { Layout } from "@noclaps/components";

import "../styles/global.css";
import "../styles/colors.css";

const links = [
  {
    slug: "https://github.com/noClaps/ZeroLimits.dev/releases/download/2023-08-13/Photos.zip",
    title: "Download",
    shortTitle: "",
  },
];

const {
  title,
  description = "A website to showcase some cool photos I've taken.",
} = Astro.props;
---

<Layout site="gallery" {title} {description} {links}>
  <slot />
</Layout>
