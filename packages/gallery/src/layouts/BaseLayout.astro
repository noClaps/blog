---
import { Layout } from "@noclaps/components";
import { Download } from "lucide-astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A website to showcase some cool photos I've taken.",
} = Astro.props;
---

<Layout {title} {description}>
  <a
    href="https://github.com/noClaps/ZeroLimits.dev/releases/download/2023-09-05/Photos.zip"
    slot="header"><Download />Download</a
  >
  <slot />
</Layout>

<style>
  a {
    display: flex;
    gap: 0.125rem;
    text-decoration: none;
    transition: all 0.25s;
    color: var(--text);
    font-weight: 550;
    padding: 0.25rem;
    border-radius: 0.25rem;
    background-position-y: -0%;
    background-image: linear-gradient(
      180deg,
      transparent 50%,
      var(--accent) 50%
    );
    transition: all 0.25s;
    background-size: auto 200%;

    &:hover {
      background-position-y: 100%;
      color: var(--on-accent);
      transition: all 0.1s ease;
    }
  }

  svg {
    height: 1rem;
  }
</style>
