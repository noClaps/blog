---
import { ThemeToggle, Sidebar, GlobalNav } from "@noclaps/components";

const links = [
  {
    slug: "Photos.zip",
    title: "Download",
    shortTitle: "",
  },
];
---

<header>
  <h3>
    <a href="/">Aperturic Focus</a>
    <ThemeToggle />
  </h3>

  <nav>
    <GlobalNav {links} />
  </nav>

  <Sidebar>
    <GlobalNav {links} />
  </Sidebar>
</header>

<style>
  header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: var(--background);
    top: 0;
    padding: 2vh 1vw;
    transition: all 0.25s;
    position: sticky;
  }

  a {
    text-decoration: none;
    padding: 0.5rem;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }

  /* Title */
  h3 {
    margin: 0;
    display: inline-flex;

    & a {
      text-decoration: none;
      color: var(--text);
      position: relative;
    }
  }

  /* Nav */
  nav {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;

    @media (max-width: 768px) {
      display: none;
    }
  }
</style>
