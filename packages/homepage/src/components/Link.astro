---
import { Icon } from "astro-icon";

interface Props {
  title: string;
  description?: string;
  link: string;
  icon: string;
}

const { title, description, link, icon } = Astro.props;
---

<a href={link}>
  <div>
    {
      icon.startsWith("https://") ? (
        <img src={icon} alt={title} />
      ) : (
        <Icon name={`octicon:${icon}-16`} />
      )
    }
    <h3>{title}</h3>
  </div>
  {description && <p>{description}</p>}
</a>

<style>
  a {
    position: relative;
    display: inline-grid;
    grid-template-rows: auto 1fr;
    grid-gap: 1rem;
    text-decoration: none;
    color: var(--text);
    padding: 1rem;
    border: 0.125rem solid var(--text);
    border-radius: 0.5rem;
    transition: all 0.25s;
    background-color: var(--background);

    &::before {
      content: "";
      position: absolute;
      inset: 0.25rem;
      background-image: var(--gradient);
      z-index: -1;
      filter: blur(0.5rem);
      transition: inset 0.25s;
      will-change: transform;
      border-radius: 0.5rem;
    }

    &:hover::before {
      inset: -0.25rem;
    }
  }

  h3,
  p {
    margin: 0;
  }

  div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: min-content;
  }

  img {
    height: 1.5rem;
    place-self: center;
    border-radius: 0.25em;
  }

  p {
    text-align: left;
  }

  [astro-icon] {
    height: 1.5rem;
  }
</style>
