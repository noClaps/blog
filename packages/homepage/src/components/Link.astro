---
import { Icon } from "@noclaps/components";

interface Props {
  title: string;
  description?: string;
  link: string;
  icon: string;
}

const { title, description, link, icon } = Astro.props;
---

<link-element {link}>
  <div>
    {
      icon.startsWith("https://") ? (
        <img src={icon} alt={title} />
      ) : (
        <Icon name={icon} />
      )
    }
    <h3>{title}</h3>
  </div>
  {description && <p>{description}</p>}
</link-element>

<style>
  link-element {
    position: absolute;
    display: inline-grid;
    grid-template-rows: auto 1fr;
    grid-gap: 1rem;
    text-decoration: none;
    color: var(--text);
    padding: 1rem;
    background-color: var(--secondary);
    border-radius: 0.5rem;
    transition: background-color 0.25s, color 0.25s;
    width: fit-content;
    max-width: 20rem;
    cursor: pointer;

    &:hover {
      background-color: var(--primary);
      color: #000000;
    }
  }

  h3,
  p {
    margin: 0;
  }

  div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: min-content;
  }

  img {
    height: 1.5rem;
    place-self: center;
    border-radius: 0.25em;
  }

  p {
    text-align: left;
  }
</style>

<script>
  import SAT from "sat";
  console.log(SAT);

  const footer = document.body.querySelector("footer") as HTMLElement;
  const header = document.body.querySelector("header") as HTMLElement;
  const landing = document.body.querySelector("#landing") as HTMLElement;

  class LinkElement extends HTMLElement {
    constructor() {
      super();

      let attempts = 0;

      while (this.checkIfOverlap() || attempts > 20) {
        // Set random position
        // The offsetHeight and offsetWidth are substracted to ensure that the link element is always on screen
        this.style.top = `${
          Math.random() * (innerHeight - this.offsetHeight)
        }px`;
        this.style.left = `${
          Math.random() * (innerWidth - this.offsetWidth)
        }px`;
        attempts++;
      }

      this.addEventListener("click", () => {
        open(this.getAttribute("link")!, "_blank");
      });
    }

    checkIfOverlap() {
      const link = this.getAttribute("link");
      const linkBox = new SAT.Box(
        new SAT.Vector(this.offsetLeft, this.offsetTop),
        this.offsetWidth,
        this.offsetHeight
      ).toPolygon();

      const otherElements = Array.from(
        document.querySelectorAll(
          `footer, header, #landing, link-element:not(link-element[link="${link}"]`
        ) as NodeListOf<HTMLElement>
      );

      const overlapCheck = otherElements.map((el) => {
        const elBox = new SAT.Box(
          new SAT.Vector(el.offsetLeft, el.offsetTop),
          el.offsetWidth,
          el.offsetHeight
        ).toPolygon();

        return SAT.testPolygonPolygon(linkBox, elBox);
      });

      return overlapCheck.includes(true);
    }
  }

  customElements.define("link-element", LinkElement);
</script>
