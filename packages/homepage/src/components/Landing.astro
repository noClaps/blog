---
import { Icon } from "astro-icon";
import Nav from "./Nav.astro";
---

<div>
  <Icon name="octicon:infinity-16" />
  <h1>ZeroLimits</h1>
  <Nav />
</div>

<style>
  div {
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 75dvh;
    margin-bottom: 25dvh;
  }

  h1 {
    font-family: system-ui;
    font-size: 4rem;
    background: var(--gradient);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0;
    filter: brightness(150%);
  }

  [astro-icon] {
    width: 50%;
    max-width: 16rem;
    filter: brightness(150%);
    animation: colorwheel-svg 10s ease-in-out infinite alternate;

    & :global(path) {
      fill: unset;
    }
  }
</style>
