---
import { Icon } from "@noclaps/components";
---

<div>
  <Icon name="infinity" />
  <h1>ZeroLimits</h1>
</div>

<style>
  div {
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 75dvh;
    margin-bottom: 25dvh;
  }

  h1 {
    font-family: system-ui;
    font-size: 4rem;
    background: var(--gradient);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    margin: 0;
    filter: var(--brightness);
  }
</style>
