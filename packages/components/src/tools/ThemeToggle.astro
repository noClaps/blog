---
import { Sun, Moon } from "lucide-astro";
---

<theme-toggle title="Theme toggle">
  <Sun class="sun" />
  <Moon class="moon" />
</theme-toggle>

<style>
  theme-toggle {
    display: none;
    padding: 0.5rem;
    color: var(--text);
    background-color: transparent;
    cursor: pointer;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }

    &:active {
      transform: scale(0.75);
    }
  }

  svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  :root.light {
    & .sun {
      display: none;
    }
  }

  :root.dark {
    & .moon {
      display: none;
    }
  }
</style>

<script>
  class ThemeToggle extends HTMLElement {
    value = "";

    constructor() {
      super();

      this.value =
        sessionStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");

      document.documentElement.style.colorScheme = this.value;
      document.documentElement.className = this.value;

      this.addEventListener("click", this.toggle);
    }

    toggle() {
      // Switch between light and dark
      if (this.value === "dark") {
        this.value = "light";
      } else {
        this.value = "dark";
      }

      // Update value in sessionStorage
      sessionStorage.setItem("theme", this.value);

      // Set body class to be updated theme value
      document.documentElement.style.colorScheme = this.value;
      document.documentElement.className = this.value;
    }
  }

  customElements.define("theme-toggle", ThemeToggle);
  document.querySelector<ThemeToggle>("theme-toggle")!.style.display = "inline-flex";
</script>
