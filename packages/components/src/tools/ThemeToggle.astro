---
import { Icon } from "astro-icon";
---

<theme-toggle title="Theme toggle">
  <Icon name="octicon:sun-16" />
  <Icon name="octicon:moon-16" />
</theme-toggle>

<style>
  theme-toggle {
    display: inline-flex;
    text-decoration: none;
    padding: 0.5rem;
    color: var(--text);
    background-color: transparent;
    cursor: pointer;

    &:hover {
      color: var(--accent);
    }
  }

  [astro-icon] {
    transition: all 0.25s;
  }

  :global(body.light) {
    & [astro-icon="octicon:moon-16"] {
      width: 1.25rem;
    }

    & [astro-icon="octicon:sun-16"] {
      width: 0;
    }
  }

  :global(body.dark) {
    & [astro-icon="octicon:moon-16"] {
      width: 0;
    }

    & [astro-icon="octicon:sun-16"] {
      width: 1.25rem;
    }
  }
</style>

<script>
  class ThemeToggle extends HTMLElement {
    value = "";

    constructor() {
      super();

      this.value =
        sessionStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");

      document.body.className = this.value;

      this.addEventListener("click", this.toggle);
    }

    toggle() {
      // Switch between light and dark
      if (this.value === "dark") {
        this.value = "light";
      } else {
        this.value = "dark";
      }

      // Update value in sessionStorage
      sessionStorage.setItem("theme", this.value);

      // Set body class to be updated theme value
      document.body.className = this.value;
    }
  }

  customElements.define("theme-toggle", ThemeToggle);
</script>
