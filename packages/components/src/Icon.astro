  )
}
{
  name === "donate" && (
    <svg class="donate" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
      <path d="M7.655 14.916v-.001h-.002l-.006-.003-.018-.01a22.066 22.066 0 0 1-3.744-2.584C2.045 10.731 0 8.35 0 5.5 0 2.836 2.086 1 4.25 1 5.797 1 7.153 1.802 8 3.02 8.847 1.802 10.203 1 11.75 1 13.914 1 16 2.836 16 5.5c0 2.85-2.044 5.231-3.886 6.818a22.094 22.094 0 0 1-3.433 2.414 7.152 7.152 0 0 1-.31.17l-.018.01-.008.004a.75.75 0 0 1-.69 0Z" />
    </svg>
  )
}
{
  name === "email" && (
    <svg class="email" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
      <path d="M1.75 2h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0 1 14.25 14H1.75A1.75 1.75 0 0 1 0 12.25v-8.5C0 2.784.784 2 1.75 2ZM1.5 12.251c0 .138.112.25.25.25h12.5a.25.25 0 0 0 .25-.25V5.809L8.38 9.397a.75.75 0 0 1-.76 0L1.5 5.809v6.442Zm13-8.181v-.32a.25.25 0 0 0-.25-.25H1.75a.25.25 0 0 0-.25.25v.32L8 7.88Z" />
    </svg>
  )
}

<style>
  svg {
    place-self: center;
    fill: currentColor;
  }

  .moon,
  .sun {
    transition: all 0.25s;
  }

  .github,
  .rss {
    height: 1.25rem;
  }

  .download,
  .arrow-up,
  .note,
  .quote,
  .warning {
    height: 1rem;
  }

  .infinity {
    width: 50%;
    max-width: 16rem;
  }

  .arrow-up {
    margin-right: 0.25rem;
  }

  .note,
  .quote,
  .warning {
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .donate,
  .email {
    height: 1.5rem;
  }
</style>
