---
import ThemeToggle from "../tools/ThemeToggle.astro";

interface Props {
  site: string;
}

const { site } = Astro.props;

const names: { [key: string]: string } = {
  blog: "The Blog of Random",
  gallery: "Aperturic Focus",
  homepage: "ZeroLimits.dev",
};
---

<header>
  <a href="/">{names[site]}</a>
  <div>
    <slot />
    <ThemeToggle />
  </div>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--background);
    top: 0;
    padding: 2vh 1vw;
    transition: all 0.25s;
    position: sticky;
    z-index: 2;
  }

  a {
    font-size: 1.25rem;
    font-weight: bold;
    text-decoration: none;
    padding: 0.5rem;
    transition: all 0.25s;
    color: var(--text);

    &:hover {
      color: var(--accent);
    }
  }

  div {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
</style>
