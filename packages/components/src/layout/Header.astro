---
import ThemeToggle from "../tools/ThemeToggle.astro";
import Nav from "./Nav.astro";
import Sidebar from "./Sidebar.astro";
import type { NavData } from "../scripts/treeify";

interface Props {
  site: string;
  links: NavData[];
}

const { site, links } = Astro.props;

const names: { [key: string]: string } = {
  blog: "The Blog of Random",
  gallery: "Aperturic Focus",
  homepage: "ZeroLimits.dev",
};
---

<header>
  <h3>
    <a href="/">{names[site]}</a>
    {site !== "homepage" && <ThemeToggle />}
  </h3>
  {
    site === "homepage" ? (
      <ThemeToggle />
    ) : (
      <>
        <nav>
          <Nav {links} />
        </nav>
        <Sidebar>
          <Nav {links} />
        </Sidebar>
      </>
    )
  }
</header>

<style>
  header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: var(--background);
    top: 0;
    padding: 2vh 1vw;
    transition: all 0.25s;
    position: sticky;
    z-index: 2;
  }

  a {
    text-decoration: none;
    padding: 0.5rem;
    transition: all 0.25s;
    color: var(--text);

    &:hover {
      color: var(--accent);
    }
  }

  /* Title */
  h3 {
    margin: 0;
    display: inline-flex;
  }

  /* Nav */
  nav {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;

    @media (max-width: 768px) {
      display: none;
    }
  }
</style>
