---
import { Home } from "lucide-astro";
import ThemeToggle from "../tools/ThemeToggle.astro";
---

<header>
  {
    Astro.url.pathname !== "/" && Astro.url.pathname !== "" ? (
      <a href="/">
        <Home />
      </a>
    ) : (
      <div />
    )
  }
  <div>
    <slot />
    <ThemeToggle />
  </div>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--background);
    top: 0;
    padding: 2vh 1vw;
    transition: all 0.25s;
    position: sticky;
    z-index: 2;
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: bold;
    text-decoration: none;
    padding: 0.5rem;
    transition: all 0.25s;
    color: var(--text);

    &:hover {
      color: var(--accent);
    }
  }

  svg {
    height: 1.25rem;
    width: 1.25rem;
    vertical-align: middle;
  }

  div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  img {
    height: 1.5rem;
  }
</style>
