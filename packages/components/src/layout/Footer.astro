---
import { Icon } from "astro-icon";
---

<footer>
  <a href="https://github.com/noClaps/ZeroLimits.dev" title="Source Code">
    <Icon name="octicon:mark-github-16" />
  </a>
  <slot />
</footer>

<style>
  footer {
    margin-top: 4rem;
    position: relative;
    display: flex;
    bottom: 0;
    padding: 1rem;
    justify-content: center;
    align-items: center;
  }

  a {
    color: var(--text);
    padding: 0.5rem;
    margin: 0 0.25rem;
    border-radius: 0.5rem;
    display: grid;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }

  [astro-icon] {
    height: 1.25rem;
  }
</style>
