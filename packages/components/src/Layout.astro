---
import Footer from "./layout/Footer.astro";
import Head from "./layout/Head.astro";
import Header from "./layout/Header.astro";
import type { NavData } from "./scripts/treeify";

import "./styles/global.css";

interface Props {
  site: string;
  title: string;
  description: string;
  links: NavData[];
}

const { site, title, description, links } = Astro.props;
---

<html lang="en">
  <Head {site} {title} {description} />
  <body>
    <Header {site} {links} />
    <slot />
    <Footer {site} />
    <style>
      body {
        display: grid;
        grid-template-rows: auto 1fr auto;
        min-height: 100dvh;
        height: fit-content;
        scroll-behavior: smooth;
        margin: 0;
      }
    </style>
  </body>
</html>
./scripts/treeify