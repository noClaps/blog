---
import Footer from "./Footer.astro";
import Head from "./Head.astro";

import "./global.css";

interface Props {
  site: string;
  title: string;
  description: string;
}

const { site, title, description } = Astro.props;
---

<html lang="en">
  <Head {site} {title} {description} />
  <body>
    <slot />
    <Footer {site} />
    <style>
      body {
        display: grid;
        grid-template-rows: auto 1fr auto;
        height: 100dvh;
        scroll-behavior: smooth;
        margin: 0;
      }
    </style>
  </body>
</html>
