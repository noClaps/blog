---
import Head from "./layout/Head.astro";
import Header from "./layout/Header.astro";

import "./styles/global.css";

interface Props {
  site: string;
  title: string;
  description: string;
}

const { site, title, description } = Astro.props;
---

<html lang="en">
  <Head {title} {description}>
    <slot name="head" />
  </Head>
  <body>
    <Header {site}>
      <slot name="header" />
    </Header>

    <slot />
    <style>
      html {
        scroll-behavior: smooth;
      }

      body {
        display: grid;
        grid-template-rows: auto 1fr;
        min-height: 95dvh;
        height: fit-content;
        margin: 0;
        background-color: var(--background);
        color: var(--text);
        transition: all 0.25s;
        margin-bottom: 5dvh;
      }
    </style>
  </body>
</html>
