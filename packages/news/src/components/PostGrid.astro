---
import Post from "./Post.astro";
import { fetchPosts } from "../scripts/fetchPosts";

const posts = await fetchPosts();
---

<div>
    {posts.map(({ title, url }) => <Post {title} {url} />)}
</div>

<style>
    div {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
        grid-gap: 1rem;
    }
</style>
