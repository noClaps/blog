---
interface Props {
    url: string;
    domain: string;
    title: string;
}

const { url, domain, title } = Astro.props;
---

<a href={url} {title} target="_blank">
    <h3>{title}</h3>
    <p>{domain}</p>
</a>

<style>
    a {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        justify-content: space-evenly;
        padding: 1rem;
        border: 0.125rem solid var(--text);
        color: var(--text);
        text-decoration: none;
        border-radius: 0.5rem;
        transition: all 0.25s;

        &:hover {
            background-color: var(--accent);
            color: var(--on-accent);
        }
    }

    h3,
    p {
        margin: 0;
    }

    p {
        hyphens: auto;
        font-size: 0.75rem;
        filter: opacity(50%);
    }
</style>
