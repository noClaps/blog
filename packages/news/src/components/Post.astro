---
interface Props {
    postId: number;
}

interface PostData {
    by: string;
    descendants: number;
    id: number;
    kids?: number[];
    score: number;
    text?: string;
    time: number;
    title: string;
    type: "story";
    url?: string;
}

const { postId } = Astro.props;

async function getPost(postId: number) {
    const post = (await fetch(
        `https://hacker-news.firebaseio.com/v0/item/${postId}.json`,
    ).then((r) => r.json())) as PostData;

    if (post.url && !post.url.startsWith("https://twitter.com")) {
        return { url: post.url, title: post.title };
    }
}

const post = await getPost(postId);
---

{
    post && (
        <a href={post.url} title={post.title} target="_blank">
            <h3>{post.title}</h3>
            <p>{new URL(post.url).origin}</p>
        </a>
    )
}
<style>
    a {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        justify-content: space-evenly;
        padding: 1rem;
        border: 0.125rem solid var(--text);
        color: var(--text);
        text-decoration: none;
        border-radius: 0.5rem;
        transition: all 0.25s;

        &:hover {
            background-color: var(--accent);
            color: var(--on-accent);
        }
    }

    h3,
    p {
        margin: 0;
    }

    p {
        hyphens: auto;
        font-size: 0.75rem;
        filter: opacity(50%);
    }
</style>
