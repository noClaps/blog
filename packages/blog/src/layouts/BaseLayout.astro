---
import { Layout } from "@noclaps/components";
import { Rss } from "lucide-astro";

import "../styles/colors.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A blog about the most random things you can think of.",
} = Astro.props;
---

<Layout {title} {description}>
  <link
    rel="alternate"
    href="/rss.xml"
    type="application/rss+xml"
    title="RSS"
    slot="head"
  />
  <a href="/rss.xml" title="Atom Feed" slot="header">
    <Rss />
  </a>
  <slot />
</Layout>

<style>
  a {
    color: var(--text);
    padding-left: 0.5rem;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }

  svg {
    height: 1.25rem;
    width: 1.25rem;
    vertical-align: middle;
  }
</style>
