---
import Slider from "../components/Slider.astro";
import { Layout } from "@noclaps/components";
import { Icon } from "astro-icon";

import "../styles/colors.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A blog about the most random things you can think of.",
} = Astro.props;
---

<Layout {title} {description}>
  <link
    slot="head"
    rel="alternate"
    href="/rss.xml"
    type="application/rss+xml"
    title="RSS"
  />
  <Fragment slot="header">
    <Slider />
    <a href="/rss.xml" title="Atom Feed">
      <Icon name="octicon:rss-16" />
    </a>
  </Fragment>
  <slot />
</Layout>

<style>
  a {
    color: var(--text);
    padding-left: 0.5rem;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }

  [astro-icon] {
    height: 1.25rem;
    vertical-align: middle;
  }
</style>
