---
import { Layout } from "@noclaps/components";
import { getCollection } from "astro:content";

import "../styles/colors.css";
import "../styles/components.css";
import "../styles/global.css";

const posts = await getCollection("posts");

const links = posts.map((post) => {
  return {
    slug: post.slug,
    title: post.data.title,
    shortTitle: post.data.shortTitle || "",
  };
});

const {
  title,
  description = "A blog about the most random things you can think of, brought to you by the most interesting boring person you've ever met.",
} = Astro.props;
---

<Layout site="blog" {title} {description} {links}>
  <slot />
</Layout>
