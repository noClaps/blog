---
import Slider from "../components/Slider.astro";
import { Icon, Layout } from "@noclaps/components";

import "../styles/colors.css";
import "../styles/components.css";
import "../styles/global.css";

const {
  title,
  description = "A blog about the most random things you can think of, brought to you by the most interesting boring person you've ever met.",
} = Astro.props;
---

<Layout site="blog" {title} {description}>
  <Fragment slot="head">
    <link
      rel="alternate"
      href="/rss.xml"
      type="application/rss+xml"
      title="RSS"
    />
  </Fragment>
  <Slider slot="header" />
  <slot />
  <Fragment slot="footer">
    <a href="/rss.xml" title="Atom Feed">
      <Icon name="rss" />
    </a>
  </Fragment>
</Layout>

<style>
  a {
    color: var(--text);
    padding: 0.5rem;
    margin: 0 0.25rem;
    border-radius: 0.5rem;
    display: grid;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }
</style>
