---
import { Icon, Layout } from "@noclaps/components";

import "../styles/colors.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A blog about the most random things you can think of.",
} = Astro.props;
---

<Layout {title} {description}>
  <link
    rel="alternate"
    href="/rss.xml"
    type="application/rss+xml"
    title="RSS"
    slot="head"
  />
  <Fragment slot="header">
    <a class="notes" href="/notes">Notes</a>
    <a class="rss" href="/rss.xml" title="Atom Feed"><Icon name="rss" /></a>
  </Fragment>
  <slot />
</Layout>

<style>
  a {
    transition: all 0.25s;
    color: var(--text);
    padding: 0.25rem;
  }

  .rss:hover {
    color: var(--accent);
  }

  .notes {
    display: flex;
    gap: 0.125rem;
    text-decoration: none;
    transition: all 0.25s;
    font-weight: 550;
    border-radius: 0.25rem;
    background-position-y: -0%;
    background-image: linear-gradient(
      180deg,
      transparent 50%,
      var(--accent) 50%
    );
    background-size: auto 200%;

    &:hover {
      background-position-y: 100%;
      color: var(--on-accent);
    }
  }

  svg {
    height: 1.25rem;
    width: 1.25rem;
    vertical-align: middle;
  }
</style>
