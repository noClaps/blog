---
import Slider from "../components/Slider.astro";
import { Layout } from "@noclaps/components";
import { Icon } from "astro-icon";

import "../styles/colors.css";
import "../styles/global.css";

const {
  title,
  description = "A blog about the most random things you can think of, brought to you by the most interesting boring person you've ever met.",
} = Astro.props;
---

<Layout site="blog" {title} {description}>
  <link
    slot="head"
    rel="alternate"
    href="/rss.xml"
    type="application/rss+xml"
    title="RSS"
  />
  <Slider slot="header" />
  <slot />
  <a slot="footer" href="/rss.xml" title="Atom Feed">
    <Icon name="octicon:rss-16" />
  </a>
</Layout>

<style>
  a {
    color: var(--text);
    padding: 0.5rem;
    margin: 0 0.25rem;
    border-radius: 0.5rem;
    display: grid;
    transition: all 0.25s;

    &:hover {
      color: var(--accent);
    }
  }

  [astro-icon] {
    height: 1.25rem;
  }
</style>
