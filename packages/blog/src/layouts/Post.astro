---
import BaseLayout from "./BaseLayout.astro";
import "../styles/post.css";
import ScrollToTop from "../components/ScrollToTop.astro";

interface Props {
  title: string;
  description: string;
  author: {
    data: {
      name: string;
      link: string;
    };
  };
  date: Date;
  lastmod?: Date;
}

const { title, description, author, date, lastmod } = Astro.props;

const pubDate = lastmod ?? date;

const titleString = title.toLowerCase().split(" ").join("");
const timeString = `${pubDate
  ?.toDateString()
  .split(" ")
  .join("")}-${titleString}`;
const descriptionString = description?.toLowerCase().split(" ").join("");
const authorString = `${author.data.name}-${titleString}`;
---

<BaseLayout {title} {description}>
  <main>
    <div class="post-header">
      <time transition:name={timeString} datetime={pubDate.toISOString()}>
        {pubDate.toDateString()}
      </time>
      <h1 transition:name={titleString}>{title}</h1>
      <div class="post-info">
        <h3 transition:name={descriptionString}>{description}</h3>
        <p transition:name={authorString}>
          Written by <a href={author.data.link}>{author.data.name}</a>
        </p>
      </div>
    </div>
    <article>
      <slot />
    </article>
    <ScrollToTop />
  </main>
</BaseLayout>

<style>
  main {
    margin-top: 4dvh;
  }

  div {
    display: flex;
  }

  /* Post header */
  .post-header {
    flex-direction: column;
  }

  h1,
  time {
    margin: 0.5rem 0;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0;
  }

  time {
    font-weight: bold;
    opacity: 0.75;
  }

  /* Post info */
  .post-info {
    justify-content: space-between;

    @media (max-width: 768px) {
      flex-direction: column;
    }
  }

  p {
    font-style: italic;
    opacity: 0.75;
  }

  a {
    color: var(--text);
    transition: all 0.25s;
  }

  h3 {
    opacity: 0.75;
    font-size: 1.25rem;
    margin: 1rem 0;
  }
</style>
