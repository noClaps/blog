---
import BaseLayout from "./BaseLayout.astro";

import "../styles/topic.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout {title}>
  <main>
    <h1>{title}</h1>
    <div>
      <slot />
    </div>
  </main>
</BaseLayout>

<style>
  main {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
  }

  h1 {
    text-align: center;
    font-size: 3rem;
  }

  div {
    display: grid;
    gap: 1rem;
  }
</style>
