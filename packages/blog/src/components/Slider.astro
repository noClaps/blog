<page-slider>
  <a href="/history/">History</a>
  <a href="/science/">Science</a>
  <a href="/tech/">Tech</a>
</page-slider>

<style>
  page-slider {
    position: relative;
    display: flex;
    border: 0.125rem solid var(--accent);
    padding: 0.25rem;
    border-radius: 0.5rem;
    justify-content: space-evenly;
    gap: 0.25rem;
    transition: box-shadow 0.25s;
    background-color: var(--background);

    &::before {
      content: "";
      position: absolute;
      z-index: -1;
      background-image: var(--accent-gradient);
      border-radius: 0.5rem;
      filter: blur(0.5rem);
      inset: 0.25rem;
      transition: inset 0.25s;
    }

    &:hover::before {
      inset: -0.25rem;
    }
  }

  a {
    color: var(--text);
    text-decoration: none;
    padding: 0.25rem;
    border-radius: 0.25rem;
    transition: all 0.25s;

    &:hover {
      font-weight: bold;
    }

    &[current-page] {
      font-weight: bold;
      color: var(--on-accent);
      background-color: var(--accent);
    }
  }
</style>

<script>
  class Slider extends HTMLElement {
    constructor() {
      super();

      const path = location.pathname;
      const currentPathElem = this.querySelector(`a[href="${path}"]`);

      if (currentPathElem) {
        currentPathElem.setAttribute("current-page", "");
      }
    }
  }

  customElements.define("page-slider", Slider);
</script>
