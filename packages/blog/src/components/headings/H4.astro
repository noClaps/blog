---
interface Props {
    id: string;
}

const { id } = Astro.props;
---

<h4 {id}>
    <a href={`#${id}`}><slot /></a>
</h4>

<style>
    h4 {
        scroll-margin-top: 4.5rem;
    }

    a {
        color: var(--text);

        &:hover {
            text-decoration: none;
        }
    }
</style>
