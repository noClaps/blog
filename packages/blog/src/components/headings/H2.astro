---
interface Props {
    id: string;
}

const { id } = Astro.props;
---

<h2 {id}>
    <a href={`#${id}`}><slot /></a>
</h2>

<style>
    h2 {
        scroll-margin-top: 4.5rem;
        border-top: solid 0.125rem var(--accent);
        padding-top: calc(4rem / 3);
        margin-top: 0.5rem;
    }

    a {
        color: var(--text);

        &:hover {
            text-decoration: none;
        }
    }
</style>
