---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<h2>{title}</h2>
<div>
  <slot />
</div>

<style>
  h2 {
    text-align: center;
    font-size: 2rem;
    border-top: solid 0.125rem var(--text);
    padding-top: calc(4rem / 3);
    margin: calc(4rem / 3) 0;
  }

  div {
    display: grid;
    gap: 1rem;
  }
</style>
