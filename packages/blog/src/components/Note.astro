---
import { StickyNote } from "lucide-astro";

interface Props {
  title?: string;
}

const { title = "NOTE" } = Astro.props;
---

<div class="note">
  <p>
    <StickyNote />
    <b>{title}</b>
  </p>
  <slot />
</div>

<style>
  .note {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    background-color: oklch(var(--note) / 25%);
    border: 0.125rem solid oklch(var(--note));
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
