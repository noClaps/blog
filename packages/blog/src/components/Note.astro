---
import { Icon } from "astro-icon";

interface Props {
  title?: string;
}

const { title = "NOTE" } = Astro.props;
---

<div class="note">
  <p>
    <Icon name="octicon:note-16" />
    <b>{title}</b>
  </p>
  <slot />
</div>

<style>
  .note {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 0.5rem 0;
    background-color: var(--background);
    position: relative;

    &::before {
      content: "";
      position: absolute;
      z-index: -1;
      background-image: var(--note-gradient);
      border-radius: 0.5rem;
      filter: blur(0.5rem);
      inset: -0.25rem;
      transition: inset 0.25s;
    }
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  [astro-icon] {
    height: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
