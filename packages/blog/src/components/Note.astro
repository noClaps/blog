---
import { Icon } from "astro-icon";
const { title } = Astro.props;
---

<div class="note">
  <p>
    <Icon name="octicon:note-16" />
    <b>{title ? title : "NOTE"}</b>
  </p>
  <slot />
</div>

<style>
  .note {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    border: 0.125rem solid var(--note);
    box-shadow: 0 0 1rem 0.125rem var(--note);
    margin: 0.5rem 0;
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  [astro-icon] {
    height: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
