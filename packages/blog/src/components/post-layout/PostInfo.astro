---
interface Props {
  author: {
    data: {
      name: string;
      link: string;
    };
  };
  description: string;
}

const { description, author } = Astro.props;
---

<div>
  <h3>{description}</h3>

  <p>
    Written by <a href={author.data.link}>{author.data.name}</a>
  </p>
</div>

<style>
  div {
    display: flex;
    justify-content: space-between;
  }

  p {
    font-style: italic;
    opacity: 0.75;
  }

  a {
    color: var(--text);
    transition: all 0.25s;
  }

  h3 {
    opacity: 0.75;
    font-size: 1.25rem;
    margin: 1rem 0;
  }
</style>
