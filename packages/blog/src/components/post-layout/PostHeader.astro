---
import PostInfo from "./PostInfo.astro";
interface Props {
  title: string;
  description: string;
  author: {
    data: {
      name: string;
      link: string;
    };
  };
  date: Date;
  lastmod: Date;
}

const { lastmod, date, title, description, author } = Astro.props;
---

<div>
  {
    lastmod ? (
      <time datetime={lastmod.toISOString()}>{lastmod.toDateString()}</time>
    ) : (
      <time datetime={date.toISOString()}>{date.toDateString()}</time>
    )
  }
  <h1>{title}</h1>
  <PostInfo {description} {author} />
</div>

<style>
  div {
    display: flex;
    flex-direction: column;
  }

  h1,
  time {
    margin: 0.5rem 0;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0;
  }

  time {
    font-weight: bold;
    opacity: 0.75;
  }
</style>
