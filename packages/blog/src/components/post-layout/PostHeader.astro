---
import PostInfo from "./PostInfo.astro";
interface Props {
  title: string;
  description: string;
  author: {
    data: {
      name: string;
      link: string;
    };
  };
  date: Date;
  lastmod: Date;
}

const { lastmod, date, title, description, author } = Astro.props;
---

<div>
  {
    lastmod ? (
      <time datetime={lastmod.toISOString()}>{lastmod.toDateString()}</time>
    ) : (
      <time datetime={date.toISOString()}>{date.toDateString()}</time>
    )
  }
  <h1>{title}</h1>
  <h3>{description}</h3>
  <PostInfo {author} />
</div>

<style>
  div {
    display: flex;
    flex-direction: column;
  }

  h1 {
    font-size: 2.5rem;
  }

  h3 {
    opacity: 0.75;
    font-size: 1.25rem;
  }

  h1,
  time,
  h3 {
    margin: 1rem 0;
    text-align: center;
  }

  time {
    font-weight: bold;
    opacity: 0.75;
  }
</style>
