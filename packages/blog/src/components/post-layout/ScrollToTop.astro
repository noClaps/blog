---
import { Icon } from "astro-icon";
---

<scroll-to-top>
  <p><Icon name="octicon:arrow-up-16" />Back to top</p>
</scroll-to-top>

<style>
  scroll-to-top {
    display: flex;
    width: fit-content;
    margin: auto;
    position: sticky;
    bottom: 1rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.25s;
    color: var(--on-accent);
    background-color: var(--accent);
    cursor: pointer;

    &:hover {
      translate: 0 -10%;
      box-shadow: 0 0 1rem 0.125rem var(--accent);
    }
  }

  p {
    font: inherit;
    font-size: 1rem;
    margin: 0;
    display: inline-flex;
  }

  [astro-icon] {
    height: 1rem;
    margin-right: 0.25rem;
  }
</style>

<script>
  class ScrollToTop extends HTMLElement {
    constructor() {
      super();

      this.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      window.onscroll = () => {
        if (window.scrollY > 64) {
          this.style.opacity = "1";
          this.style.translate = "0";
          this.inert = false;
        } else {
          this.style.opacity = "0";
          this.style.translate = "0 100%";
          this.inert = true;
        }
      };
    }
  }

  customElements.define("scroll-to-top", ScrollToTop);
</script>
