---
import { getCollection } from "astro:content";
import { ThemeToggle, Sidebar, GlobalNav } from "@noclaps/components";

const posts = await getCollection("posts");

const links = posts.map((post) => {
  return {
    slug: post.slug,
    title: post.data.title,
    shortTitle: post.data.shortTitle || "",
  };
});
---

<header>
  <h3>
    <a href="/">The Blog of Random</a>
    <ThemeToggle />
  </h3>
  <nav id="nav">
    <GlobalNav {links} />
  </nav>
  <Sidebar>
    <GlobalNav {links} />
  </Sidebar>
</header>

<style>
  header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: var(--background);
    top: 0;
    padding: 2vh 1vw;
    position: sticky;
    z-index: 2;
    transition: all 0.25s;
  }

  h3 {
    margin: 0;
    display: inline-flex;
  }

  a {
    text-decoration: none;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.25s;
    color: var(--text);

    &:hover {
      color: var(--accent);
    }
  }

  /* Nav */
  nav {
    display: none;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;

    @media (min-width: 769px) {
      display: flex;
    }
  }
</style>
