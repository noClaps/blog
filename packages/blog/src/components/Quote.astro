---
import { MessageSquare } from "lucide-astro";

interface Props {
  name?: string;
  link?: string;
}

const { name = "QUOTE", link } = Astro.props;
---

<blockquote class="quote">
  <p>
    <MessageSquare />
    {
      link ? (
        <b>
          <a href={link} target="_blank" rel="noopener noreferrer">
            {name}
          </a>
        </b>
      ) : (
        <b>{name}</b>
      )
    }
  </p>
  <slot />
</blockquote>

<style>
  .quote {
    display: grid;
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 0.5rem 0;
    background-color: var(--background);
    position: relative;

    &::before {
      content: "";
      position: absolute;
      z-index: -1;
      background-image: var(--quote-gradient);
      border-radius: 0.5rem;
      filter: blur(0.5rem);
      inset: -0.25rem;
      transition: inset 0.25s;
    }
  }

  p {
    margin: 0;
  }

  b {
    vertical-align: middle;
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
</style>
