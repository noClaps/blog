---
import { Icon } from "@noclaps/components";
---

<a href="#"><Icon name="arrowUp" />Back to top</a>

<style>
  a {
    display: flex;
    width: fit-content;
    margin: auto;
    position: sticky;
    bottom: 1rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.25s;
    color: var(--on-accent);
    background-color: var(--accent);
    cursor: pointer;
    align-items: center;

    &:hover {
      bottom: 1.25rem;
      box-shadow: 0 0 0.5rem 0.25rem var(--accent);
      text-decoration: none;
    }
  }

  svg {
    height: 1rem;
    width: 1rem;
    margin-right: 0.25rem;
  }
</style>
