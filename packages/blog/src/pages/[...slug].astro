---
import { getCollection, getEntry } from "astro:content";
import Post from "../layouts/Post.astro";
import Quote from "../components/Quote.astro";
import Note from "../components/Note.astro";
import Warning from "../components/Warning.astro";
import Math from "../components/Math.astro";
import H2 from "../components/headings/H2.astro";
import H3 from "../components/headings/H3.astro";
import H4 from "../components/headings/H4.astro";
import H5 from "../components/headings/H5.astro";
import H6 from "../components/headings/H6.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Post
  title={post.data.title}
  description={post.data.description}
  author={await getEntry("authors", post.data.author.id)}
  date={post.data.date}
  lastmod={post.data.lastmod}
>
  <Content
    components={{
      Quote,
      Note,
      Warning,
      Math,
      h2: H2,
      h3: H3,
      h4: H4,
      h5: H5,
      h6: H6,
    }}
  />
</Post>
